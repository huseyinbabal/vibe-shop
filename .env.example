# Postgres'in host'a açılan portu (varsayılan 5432; doluysa örn. 5455 yapın
# ve DATABASE_URL'i de aynı porta güncelleyin)
# POSTGRES_PORT=5432
DATABASE_URL=postgres://vibeshop:vibeshop@localhost:5432/vibeshop?sslmode=disable
KEYCLOAK_ISSUER_URL=http://localhost:8081/realms/vibe-shop
# API dinleme adresi (varsayılan :8080; 8080 doluysa örn. :8090 yapın ve
# frontend/.env.local içinde VITE_API_URL'i aynı porta güncelleyin)
# ADDR=:8080
